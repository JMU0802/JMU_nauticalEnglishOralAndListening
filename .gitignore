# ── Python 缓存 ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── 环境变量 / API Keys（切勿提交）────────────────────────────────
.env
.env.*
!.env.example

# ── 虚拟环境 ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── AI 模型（体积巨大，不纳入 git）──────────────────────────────
models/whisper/
models/tts/
models/sbert/
# 仅保留 .gitkeep
!models/whisper/.gitkeep
!models/tts/.gitkeep
!models/sbert/.gitkeep

# ── 原始音频数据包（> 100 MB，不纳入 git）─────────────────────
SMCP_DATA/audioFile/*.rar
SMCP_DATA/audioFile/*.zip
# 大型 PDF 参考文档（> 10 MB）
SMCP_DATA/docs/3317.-Maritime-English-for-the-Merchant-Marine-Academy-Grecia.pdf

# ── 数据库文件 ─────────────────────────────────────────────────────
corpus/db/*.db
corpus/db/*.db-shm
corpus/db/*.db-wal

# ── 测试 & 覆盖率 ──────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── 打包输出 ─────────────────────────────────────────────────────
dist/
*.spec.bak

# ── IDE / 编辑器 ──────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── LightRAG 服务目录（源码为子仓库，不纳入本仓库）────────────────
# 克隆方式：git clone https://github.com/HKUDS/LightRAG.git lightrag
# 部署文件在项目根目录：local_embedding_server.py, start_lightrag.ps1
lightrag/

# ── 临时音频文件 ─────────────────────────────────────────────────
*.wav
*.mp3
!assets/audio/*.wav

# ── 日志 ────────────────────────────────────────────────────────
*.log
logs/

# ── OS 文件 ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
