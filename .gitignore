# ── Python 缓存 ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── 虚拟环境 ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── AI 模型（体积巨大，不纳入 git）──────────────────────────────
models/whisper/
models/tts/
# 仅保留 .gitkeep
!models/whisper/.gitkeep
!models/tts/.gitkeep

# ── 数据库文件 ─────────────────────────────────────────────────────
corpus/db/*.db
corpus/db/*.db-shm
corpus/db/*.db-wal

# ── 测试 & 覆盖率 ──────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── 打包输出 ─────────────────────────────────────────────────────
dist/
*.spec.bak

# ── IDE / 编辑器 ──────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── 临时音频文件 ─────────────────────────────────────────────────
*.wav
*.mp3
!assets/audio/*.wav

# ── 日志 ────────────────────────────────────────────────────────
*.log
logs/

# ── OS 文件 ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
